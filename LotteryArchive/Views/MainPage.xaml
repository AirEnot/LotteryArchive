<Page x:Class="LotteryArchive.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="MainPage">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Style="{StaticResource PageTitleStyle}"
                   Text="Все лотереи"
                   Margin="0,0,0,12" />

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Text="Формат сохранения:" />
                <ComboBox x:Name="FormatCombo" Grid.Column="2" SelectionChanged="FormatCombo_OnSelectionChanged">
                    <ComboBoxItem Content="JSON" />
                    <ComboBoxItem Content="XML" />
                </ComboBox>
                <Button Grid.Column="4"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Content="Статистика участников"
                        Click="StatisticsButton_OnClick" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <TextBlock x:Name="EmptyLotteriesText"
                       Visibility="Collapsed"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="18"
                       Foreground="Gray"
                       Text="Лотерии пока не созданы" />

            <ListBox x:Name="LotteriesList"
                     BorderThickness="0"
                     Background="Transparent"
                     HorizontalContentAlignment="Stretch"
                     MouseDoubleClick="LotteriesList_OnMouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,8" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Opacity="{Binding CardOpacity}" Style="{StaticResource CardBorderStyle}" Cursor="Hand">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <Border Grid.Column="1" Margin="8,0,0,0" Padding="10,4" CornerRadius="12" VerticalAlignment="Top">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FFE8F5E9" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDrawn}" Value="True">
                                                        <Setter Property="Background" Value="#FFEEEEEE" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" FontSize="12" />
                                    </Border>
                                </Grid>
                                <TextBlock Margin="0,8,0,0" Text="{Binding TicketsCount, StringFormat=Билетов: {0}}" />
                                <TextBlock Margin="0,4,0,0" Text="{Binding TicketsPrice, StringFormat=Цена билета: {0}}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding PrizePoolText}"
                                           FontWeight="SemiBold"
                                           FontSize="16"
                                           Foreground="{StaticResource AccentBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource BottomBarStyle}" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource SecondaryButtonStyle}" Content="Посмотреть таблицу участников" Click="ParticipantsButton_OnClick" />
                <Button Grid.Column="2" Style="{StaticResource PrimaryButtonStyle}" Content="Добавить лотерею" Click="CreateLotteryButton_OnClick" />
            </Grid>
        </Border>
    </Grid>
</Page>
