<Page x:Class="LotteryArchive.Views.CreateParticipantPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="CreateParticipantPage">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Style="{StaticResource PageTitleStyle}"
                   Text="Создание участника"
                   Margin="0,0,0,12" />

        <Border Grid.Row="1" Style="{StaticResource FormCardStyle}">
            <StackPanel>
                <TextBlock Text="ФИО участника" FontWeight="SemiBold" />
                <TextBox x:Name="FullNameBox" Margin="0,6,0,14" MaxLength="150" />

                <TextBlock Text="Баланс" FontWeight="SemiBold" />
                <TextBox x:Name="BalanceBox"
                         Margin="0,6,0,14"
                         PreviewTextInput="NumericBox_OnPreviewTextInput" />

                <TextBlock Text="Жадность (0–100)" FontWeight="SemiBold" />
                <TextBox x:Name="GreedBox"
                         Margin="0,6,0,8"
                         PreviewTextInput="NumericBox_OnPreviewTextInput" />

                <TextBlock x:Name="ValidationText"
                           Foreground="IndianRed"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource BottomBarStyle}" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Content="Назад"
                        Click="BackButton_OnClick" />
                <Button Grid.Column="2"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Content="Создать"
                        Click="CreateButton_OnClick" />
            </Grid>
        </Border>
    </Grid>
</Page>
