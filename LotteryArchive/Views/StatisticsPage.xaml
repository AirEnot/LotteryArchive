<Page x:Class="LotteryArchive.Views.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:LotteryArchive.Controls"
      Title="StatisticsPage">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource PageTitleStyle}" Text="Статистика участников" Margin="0,0,0,12" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,8" Text="Участники (отметьте для диаграммы)" />
                    <ListBox x:Name="ParticipantsCheckList" BorderThickness="0" MaxHeight="500">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding FullName}"
                                          Checked="ParticipantCheckBox_Changed"
                                          Unchecked="ParticipantCheckBox_Changed"
                                          Margin="0,4" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,8" Text="Потрачено и выиграно" />
                    <controls:SimpleBarChart x:Name="StatsChart" MinHeight="300" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource BottomBarStyle}" Margin="0,12,0,0">
            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Назад" Click="BackButton_OnClick" />
        </Border>
    </Grid>
</Page>
